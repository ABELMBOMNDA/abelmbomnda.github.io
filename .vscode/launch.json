{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Backend",
            "cwd": "${workspaceFolder}/data/abel-portfolio-fullstack/backend",
            "runtimeExecutable": "node",
            "runtimeArgs": ["--inspect"],
            "program": "${workspaceFolder}/data/abel-portfolio-fullstack/backend/server.js",
            "env": { "PORT": "5001" },
            "preLaunchTask": "kill-port-5001",
            "skipFiles": ["<node_internals>/**"],
            "outputCapture": "std"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Chrome",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/data/abel-portfolio-fullstack/frontend/src"
        }
    ],
    "compounds": [
        {
            "name": "Full Stack (Chrome + Safari)",
            "configurations": ["Backend", "Chrome"],
            "preLaunchTask": "Run Full Stack",
            "postDebugTask": "Open Safari",
            "stopAll": true
        }
    ]
}
